# Server
PORT=5000

# Database
DATABASE_URL=DATABASE_URL=postgresql://username:password@localhost:5432/db_name

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# =========================
# Code Execution Engine (Self-hosted Judge0)
# =========================

# Base URL of your Judge0 instance
JUDGE0_API_URL=http://localhost:2358

# Optional - if you enable authentication on your instance
JUDGE0_API_TOKEN=your_optional_auth_token_here

# Optional - for scaling or remote server
# Example:
# JUDGE0_API_URL=http://your-vps-ip:2358

# Google & Github login api keys
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here